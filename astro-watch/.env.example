# NASA API Configuration
NASA_API_KEY=your_nasa_api_key_here
NEXT_PUBLIC_NASA_API_BASE=https://api.nasa.gov/neo/rest/v1

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true

# Optional: Analytics and Monitoring
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
NEXT_PUBLIC_VERCEL_SPEED_INSIGHTS_ID=

# Alerting / Email
# Resend API key for sending email alerts (https://resend.com)
RESEND_API_KEY=
# Destination email for critical asteroid alerts
NOTIFICATION_EMAIL=0xFriday@pm.me
# Optional thresholds (defaults shown)
ALERT_TORINO_MIN=6
ALERT_RISK_MIN=0.75
ALERT_ONLY_PHA=true
# Optional sender (defaults to onboarding@resend.dev if not set)
ALERT_FROM_EMAIL=

# Development Settings
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Ollama Cloud (Chat Assistant)
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
OLLAMA_CLOUD_MODEL=gemma4:31b-cloud

# Autonomous Agent (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key
KV_REST_API_URL=your_vercel_kv_url
KV_REST_API_TOKEN=your_vercel_kv_token
