# NASA API Configuration
NASA_API_KEY=your_nasa_api_key_here
NEXT_PUBLIC_NASA_API_BASE=https://api.nasa.gov/neo/rest/v1

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true
NEXT_PUBLIC_ML_MODEL_CACHE_TIMEOUT=86400000

# =============================================================================
# Agentic Information Retrieval System
# =============================================================================

# Google Gemini API (for LLM reasoning)
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# Ubuntu Server - Embedding Service
# URL to your self-hosted embedding server (Ollama + pgvector)
EMBED_SERVICE_URL=https://your-ubuntu-server:8000
# Auth token for the embedding service (must match API_TOKEN on server)
EMBED_SERVICE_TOKEN=your_secret_token_here

# PostgreSQL Database (on Ubuntu server)
# Connection string for pgvector database
DATABASE_URL=postgresql://astrowatch:your_password@your-ubuntu-server:5432/astrowatch

# Admin token for asteroid data ingestion
# Required to call /api/ingest endpoint
INGEST_API_TOKEN=admin_token_for_ingestion

# Optional: Enable LLM evaluation logging
ENABLE_LLM_EVAL=false

# =============================================================================
# Analytics and Monitoring
# =============================================================================

# Optional: Analytics and Monitoring
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
NEXT_PUBLIC_VERCEL_SPEED_INSIGHTS_ID=

# =============================================================================
# Alerting / Email
# =============================================================================

# Resend API key for sending email alerts (https://resend.com)
RESEND_API_KEY=
# Destination email for critical asteroid alerts
NOTIFICATION_EMAIL=0xFriday@pm.me
# Optional thresholds (defaults shown)
ALERT_TORINO_MIN=6
ALERT_RISK_MIN=0.75
ALERT_ONLY_PHA=true
# Optional sender (defaults to onboarding@resend.dev if not set)
ALERT_FROM_EMAIL=

# =============================================================================
# Development Settings
# =============================================================================

NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
